# Telegram bot
BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
MINI_APP_URL=https://your-mini-app.example.com

# Backend
BACKEND_URL=http://localhost:8000
DATABASE_URL=sqlite:///./stem_case_bot.db

# Comma-separated Telegram user IDs that get the teacher role
TEACHER_TELEGRAM_IDS=

# Shared secret between backend and bot for internal /api/bot/* endpoints
INTERNAL_BOT_TOKEN=change-me

# Optional — Groq AI for "explain this concept" / hints
GROQ_API_KEY=

# Frontend (Vite reads from project root via envDir: '../')
VITE_API_URL=/api
